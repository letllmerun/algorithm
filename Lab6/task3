import random

# Function to shift a row to the right
def shift_right(row):
    new_row = [x for x in row if x != 0]
    zeros = [0] * (len(row) - len(new_row))
    return zeros + new_row

# Create 4x4 field
matrix = []

for i in range(4):
    row = []
    for j in range(4):
        row.append(random.randint(0, 9))
    matrix.append(row)

print("Field before shift:")
for row in matrix:
    for value in row:
        print(f"{value:4}", end="")
    print()

# Shift all rows to the right
for i in range(4):
    matrix[i] = shift_right(matrix[i])

print("\nField after shift to the right:")
for row in matrix:
    for value in row:
        print(f"{value:4}", end="")
    print()
