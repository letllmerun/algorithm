class Node:
    def __init__(self, data):
        self.data = data
        self.next = None


# Creating nodes and linking them
node1 = Node(10)
node2 = Node(20)
node3 = Node(30)

node1.next = node2
node2.next = node3

print("Task 1 result:")
current = node1
while current:
    print(current.data, end=" ")
    current = current.next
print("\n")
